<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2010/07/nuspec.xsd">
  <metadata>
    <id>GE-Multilin-G30-G60-Converter</id>
    <version>$version$</version>
    <title>GE Multilin UR G30 to G60 Converter</title>
    <authors>Jakehallmark</authors>
    <owners>Jakehallmark</owners>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Windows GUI for converting GE Multilin UR G30 relay settings XML to G60 format. Bundles firmware 840/850/860/870 base templates.</description>
    <repository type="git" url="https://github.com/Jakehallmark/GE-Multilin-UR-G30-G60-Conversion" />
    <tags>ge multilin ur g30 g60 converter</tags>
  </metadata>
  <files>
    <file src="release\G30-to-G60-Converter.exe" target="tools" />
  </files>
</package>
