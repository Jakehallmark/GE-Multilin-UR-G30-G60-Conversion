# Copy to signing.local.ps1 (gitignored) and fill in your values.
# build.ps1 -Sign loads this file automatically when present.
#
# For SmartScreen / SharePoint downloads use a PublicTrust profile (not PrivateTrust).
# Create one in Azure Portal: jhallmarksigning -> Certificate profiles -> + Public Trust

$env:ARTIFACT_SIGNING_ENDPOINT = "https://eus.codesigning.azure.net/"
$env:ARTIFACT_SIGNING_ACCOUNT  = "jhallmarksigning"
$env:ARTIFACT_SIGNING_PROFILE  = "public"

# Use azure-cli (recommended) or azure-powershell
$env:AZURE_CREDENTIAL_TYPE = "azure-cli"
