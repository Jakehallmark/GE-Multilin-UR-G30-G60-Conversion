firmware/**/*.SFD
firmware/**/*.sfd
firmware/**/*.000
firmware/**/*.VRC
firmware/**/*.vrc
_tmp_signal_probe/
_tmp_firmware_list.txt

# Azure function_app copies are synced at deploy time (not stored in git)
azure/function_app/G60 Base*.xml
azure/function_app/bases/

# Conversion reports and other HTML output
*.html

# Local test fixtures and dev scripts
test_*.py
**/validate_bases.py
HCHPublix*.xml
Leesburg*.xml
Publix*.xml

