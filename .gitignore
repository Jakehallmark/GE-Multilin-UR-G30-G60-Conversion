build/
packaging/out/
dist/
aio/build/
aio/dist/
aio/pack-staging/
aio/*.spec
aio/signing.local.ps1

# Python
__pycache__/
*.py[cod]
*$py.class
.Python
.venv/
venv/
.python_packages/

# Azure Function local secrets and deploy zips
azure/function_app/local.settings.json
azure/*.zip

# OS / editor
.DS_Store
Thumbs.db
desktop.ini
*.swp
*~
/.vscode/
.vscode/

