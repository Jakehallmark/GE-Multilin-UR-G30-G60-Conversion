firmware/**/*.SFD
firmware/**/*.sfd
firmware/**/*.000
firmware/**/*.VRC
firmware/**/*.vrc
_tmp_signal_probe/
_tmp_firmware_list.txt

# Conversion reports and other HTML output
*.html

# Local test fixtures and dev scripts
test_*.py
**/validate_bases.py
HCHPublix*.xml
Leesburg*.xml
Publix*.xml

# PyInstaller / packaging output
build/
packaging/out/
dist/
aio/build/
aio/dist/
aio/pack-staging/
aio/*.spec

# Python
__pycache__/
*.py[cod]
*$py.class
.Python
.venv/
venv/
.python_packages/

# OS / editor
.DS_Store
Thumbs.db
desktop.ini
*.swp
*~
/.vscode/
.vscode/

